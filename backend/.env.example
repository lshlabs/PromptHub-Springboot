# PromptHub Spring Backend Local Environment Template
# 이 파일을 복사하여 `.env`를 생성하고 실제 값을 입력하세요. (.env는 gitignore 필수)

# Database Configuration (Docker Local Default)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/prompthub
SPRING_DATASOURCE_USERNAME=myuser
SPRING_DATASOURCE_PASSWORD=secret
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Google OAuth (Backend-side ID token audience check)
BACKEND_GOOGLE_CLIENT_ID=your_google_client_id_here

# JWT Configuration
APP_JWT_SECRET=your_jwt_secret_key_here
APP_JWT_ACCESS_EXPIRATION_MS=3600000
APP_JWT_REFRESH_EXPIRATION_MS=1209600000